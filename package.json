{
  "private": true,
  "scripts": {
    "analyze": "ANALYZE=true next build",
    "build": "yarn generate && next build",
    "dev": "concurrently \"next dev -p 3333\" \"yarn generate --watch \\\"{components,pages}/**/*{.ts,.tsx}\\\"\"",
    "format": "npx prettier --write . --ignore-path .gitignore",
    "generate": "npx graphql-codegen --config codegen.ts",
    "graphql-deploy": "sanity graphql deploy",
    "lint": "eslint .",
    "lint:fix": "yarn format && yarn lint --fix",
    "ngrok-start": "ngrok http 3000",
    "start": "next start",
    "type-check": "tsc --noEmit",
    "revalidate": "tsx scripts/revalidate.ts",
    "test": "vitest run",
    "test:ui": "vitest --ui",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "prepare": "husky"
  },
  "prettier": {
    "semi": true,
    "singleQuote": true
  },
  "dependencies": {
    "@apollo/client": "^4.1.6",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.0",
    "@mui/icons-material": "^7.3.9",
    "@mui/material": "^7.3.9",
    "@portabletext/react": "^6.0.3",
    "@sanity/client": "^7.17.0",
    "@sanity/code-input": "^7.0.11",
    "@sanity/demo": "^1.0.1",
    "@sanity/image-url": "^1.0.2",
    "@sanity/preview-url-secret": "^4.0.3",
    "@sanity/vision": "^3.1.4",
    "@sanity/webhook": "^2.0.0",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "clsx": "^2.1.1",
    "dotenv": "^16.4.5",
    "get-it": "^8.7.0",
    "graphql": "^16.13.1",
    "make-error": "^1.3.6",
    "next": "^16.1.6",
    "next-sanity": "^12.1.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-syntax-highlighter": "^16.1.1",
    "sanity": "^5.16.0",
    "sharp": "^0.33.5",
    "styled-components": "^6.3.11",
    "suspend-react": "^0.1.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@graphql-codegen/cli": "^5.0.3",
    "@graphql-codegen/client-preset": "^4.5.1",
    "@graphql-codegen/introspection": "^4.0.3",
    "@next/bundle-analyzer": "^15.2.4",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/cli": "^4.0.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@typescript-eslint/parser": "^7.18.0",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitejs/plugin-react-swc": "^4.3.0",
    "autoprefixer": "^10.4.27",
    "concurrently": "^9.1.2",
    "eslint": "^8.57.1",
    "eslint-config-next": "15.2.4",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "eslint-plugin-unused-imports": "^3.2.0",
    "eslint-prettier": "^0.0.0-empty",
    "husky": "^9.1.7",
    "jsdom": "^28.1.0",
    "lint-staged": "^16.4.0",
    "ngrok": "^4.3.3",
    "postcss": "^8.5.8",
    "prettier": "^3.4.2",
    "prettier-plugin-packagejson": "^2.5.6",
    "prettier-plugin-tailwindcss": "^0.6.11",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.3",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  },
  "engines": {
    "node": ">=24"
  },
  "packageManager": "yarn@4.7.0",
  "resolutions": {
    "get-it": "^8.7.0",
    "@sanity/client": ">=6.1.5",
    "@codemirror/state": "6.6.0",
    "@codemirror/view": "6.40.0",
    "@codemirror/language": "6.12.2",
    "fsevents": "2.3.3",
    "minimatch@npm:^3.0.4": "3.1.5",
    "minimatch@npm:^3.0.5": "3.1.5",
    "minimatch@npm:^3.1.2": "3.1.5"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix"
    ]
  }
}
