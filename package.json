{
  "private": true,
  "scripts": {
    "analyze": "ANALYZE=true bun run --bun next build",
    "build": "bun run generate && bun run --bun next build",
    "dev": "concurrently \"bun run dev:next\" \"bun run dev:generate\"",
    "dev:next": "bun run --bun next dev -p 3333",
    "dev:generate": "bun run generate --watch \\\"{components,pages}/**/*{.ts,.tsx}\\\"",
    "format": "bunx prettier --write . --ignore-path .gitignore",
    "generate": "bunx graphql-codegen --config codegen.ts",
    "graphql-deploy": "sanity graphql deploy",
    "graphql-deploy:prod": "sanity graphql deploy --dataset=production --force",
    "lint": "eslint .",
    "lint:fix": "bun run format && bun run lint --fix",
    "ngrok-start": "ngrok http 3000",
    "start": "bun --bun next start",
    "type-check": "tsc --noEmit",
    "revalidate": "tsx scripts/revalidate.ts",
    "test": "vitest run",
    "test:ui": "vitest --ui",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "knip": "bunx knip",
    "knip:strict": "bunx knip --strict",
    "test:coverage": "vitest run --coverage",
    "check": "bun run lint && bun run type-check && bun run test && bun run knip",
    "deps:audit": "bunx npm-check-updates --target minor",
    "prepare": "husky"
  },
  "dependencies": {
    "@apollo/client": "^4.1.6",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^7.3.9",
    "@mui/material": "^7.3.9",
    "@portabletext/react": "^6.0.3",
    "@sanity/client": "^7.17.0",
    "@sanity/code-input": "^7.0.11",
    "@sanity/image-url": "^1.2.0",
    "@sanity/preview-url-secret": "^4.0.3",
    "@sanity/vision": "^5.16.0",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "clsx": "^2.1.1",
    "dotenv": "^16.6.1",
    "graphql": "^16.13.1",
    "next": "^16.1.6",
    "next-sanity": "^12.1.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-syntax-highlighter": "^16.1.1",
    "sanity": "^5.16.0",
    "styled-components": "^6.3.11",
    "suspend-react": "^0.1.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@graphql-codegen/cli": "^5.0.7",
    "@graphql-codegen/client-preset": "^4.8.3",
    "@next/bundle-analyzer": "^15.5.12",
    "@playwright/test": "^1.58.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@typescript-eslint/parser": "^7.18.0",
    "@vitejs/plugin-react-swc": "^4.3.0",
    "autoprefixer": "^10.4.27",
    "concurrently": "^9.2.1",
    "eslint": "^8.57.1",
    "eslint-config-next": "15.5.12",
    "eslint-config-prettier": "^9.1.2",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "eslint-plugin-unused-imports": "^3.2.0",
    "husky": "^9.1.7",
    "jsdom": "^28.1.0",
    "lint-staged": "^16.4.0",
    "ngrok": "^4.3.3",
    "postcss": "^8.5.8",
    "prettier": "^3.8.1",
    "eslint-plugin-import": "^2.32.0",
    "tailwindcss": "^3.4.19",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0",
    "knip": "^5.86.0",
    "npm-check-updates": "^17.1.18"
  },
  "engines": {
    "node": ">=24"
  },
  "packageManager": "bun@1.3.10",
  "resolutions": {
    "get-it": "^8.7.0",
    "@sanity/client": ">=6.1.5",
    "@codemirror/state": "6.6.0",
    "@codemirror/view": "6.40.0",
    "@codemirror/language": "6.12.2",
    "fsevents": "2.3.3",
    "minimatch@npm:^3.0.4": "3.1.5",
    "minimatch@npm:^3.0.5": "3.1.5",
    "minimatch@npm:^3.1.2": "3.1.5"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix"
    ]
  }
}
