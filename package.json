{
  "private": true,
  "scripts": {
    "analyze": "ANALYZE=true next build",
    "build": "yarn generate && next build",
    "dev": "concurrently \"next dev -p 3333\" \"yarn generate --watch \\\"{components,pages}/**/*{.ts,.tsx}\\\"\"",
    "format": "npx prettier --write . --ignore-path .gitignore",
    "generate": "npx graphql-codegen --config codegen.ts",
    "graphql-deploy": "sanity graphql deploy",
    "lint": "next lint -- --ignore-path .gitignore",
    "lint:fix": "npm run format && npm run lint -- --fix",
    "ngrok-start": "ngrok http 3000",
    "start": "next start",
    "type-check": "tsc --noEmit",
    "revalidate": "tsx scripts/revalidate.ts"
  },
  "prettier": {
    "semi": true,
    "singleQuote": true
  },
  "dependencies": {
    "@apollo/client": "^4.1.6",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.0",
    "@mui/icons-material": "^7.3.9",
    "@mui/material": "^7.3.9",
    "@sanity/client": "^7.17.0",
    "@sanity/demo": "^1.0.1",
    "@sanity/image-url": "^1.0.2",
    "@sanity/preview-url-secret": "^4.0.3",
    "@sanity/vision": "^3.1.4",
    "@sanity/webhook": "^2.0.0",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "clsx": "^2.1.1",
    "dotenv": "^16.4.5",
    "get-it": "^8.7.0",
    "graphql": "^16.13.1",
    "make-error": "^1.3.6",
    "next": "^15.2.4",
    "next-sanity": "^12.1.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "sanity": "^5.16.0",
    "sharp": "^0.33.5",
    "styled-components": "^6.3.11",
    "suspend-react": "^0.1.3"
  },
  "devDependencies": {
    "@graphql-codegen/cli": "^5.0.3",
    "@graphql-codegen/client-preset": "^4.5.1",
    "@graphql-codegen/introspection": "^4.0.3",
    "@next/bundle-analyzer": "^15.2.4",
    "@tailwindcss/cli": "^4.0.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@typescript-eslint/parser": "^7.18.0",
    "autoprefixer": "^10.4.27",
    "concurrently": "^9.1.2",
    "eslint": "^8.57.1",
    "eslint-config-next": "15.2.4",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "eslint-plugin-unused-imports": "^3.2.0",
    "eslint-prettier": "^0.0.0-empty",
    "ngrok": "^4.3.3",
    "postcss": "^8.5.8",
    "prettier": "^3.4.2",
    "prettier-plugin-packagejson": "^2.5.6",
    "prettier-plugin-tailwindcss": "^0.6.11",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.3",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=24"
  },
  "packageManager": "yarn@1.22.22+sha512.a6b2f7906b721bba3d67d4aff083df04dad64c399707841b7acf00f6b133b7ac24255f2652fa22ae3534329dc6180534e98d17432037ff6fd140556e2bb3137e",
